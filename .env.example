# Duepi Remote IoT - Configuration
# Copy this file to .env and fill in your values.
# .env is ignored by git.

# Required: Device ID (find it on https://dpremoteiot.com/dashboard,
# inspect the 'delete device' button, you will find deviceid=)
DUEPI_DEVICE_ID=

# Optional: Short/univocal ID (find it in your app or sticker)
DUEPI_SHORT_ID=

# Required: Session cookie (find it using browser developer tools)
# Can include or omit the "session=" prefix
DUEPI_SESSION_COOKIE=

# Optional: Default power level (1-5, default: 5)
DUEPI_SETTED_POWER=5

# Optional: Default temperature in Celsius (default: 25)
DUEPI_SETTED_TEMPERATURE=25

# Optional: Log level (DEBUG, INFO, WARNING, ERROR; default: INFO)
DUEPI_LOG_LEVEL=INFO
